# FG Tool environment variables
# Copy this file to .env (do NOT commit .env to version control) and fill values.

# AES key used to decrypt/encrypt AES-wrapped .fg payloads.
# The UTF-8 byte length must be 16, 24, or 32 bytes.
# Example: FUGRADE_AES_KEY=your-32-byte-key-here
FUGRADE_AES_KEY=

# Password hash used when writing .cmt files (compatibility default = MD5("1")).
FUGRADE_CMT_PASSWORD_HASH=

# Note: Instead of creating a .env file you can export these variables in your shell.
# On PowerShell (current session):
#   $env:FUGRADE_AES_KEY = 'your-key'
#   $env:FUGRADE_CMT_PASSWORD_HASH = 'your-hash'
# On CMD (current session):
#   set FUGRADE_AES_KEY=your-key
#   set FUGRADE_CMT_PASSWORD_HASH=your-hash
